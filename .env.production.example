WEB_DOMAIN=app.example.com
API_DOMAIN=api.example.com
WEB_IMAGE=ghcr.io/hafzism/collability-web:latest
API_IMAGE=ghcr.io/hafzism/collability-api:latest

NODE_ENV=production
PORT=3001
WEB_APP_URL=https://app.example.com
NEXT_PUBLIC_API_URL=https://api.example.com

DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

JWT_SECRET=replace-with-a-long-random-access-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_TTL_MS=604800000
OTP_EXPIRES_MINUTES=10
OTP_VERIFICATION_SECRET=replace-with-a-different-long-random-otp-secret
OTP_VERIFICATION_EXPIRES_IN=30m

API_RATE_LIMIT_TTL_MS=60000
API_RATE_LIMIT_MAX=100
API_JSON_BODY_LIMIT=1mb
API_URLENCODED_BODY_LIMIT=1mb
NOTIFICATION_REMINDER_WORKER_ENABLED=true

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@example.com
